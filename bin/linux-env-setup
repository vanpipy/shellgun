#!/usr/bin/env bash
#
# =============================================================================
# linux-env-setup - Linux Development Environment Setup Script
# =============================================================================
#
# Description:
#   Automated setup script for Linux development environment including git, tmux,
#   zsh, neovim, volta (Node.js), gvm (Go), and pyenv (Python).
#
# Usage:
#   ./linux-env-setup [OPTIONS]
#
# Options:
#   --neovim-version VERSION  Neovim version (default: 0.12.1)
#   --reinstall TOOL         Reinstall tool (volta, gvm, neovim)
#   --proxy PROXY            Proxy (http://, https://, socks://, socks5://, default: http://127.0.0.1:7890)
#   -h, --help              Show this help message
#
# Examples:
#   ./linux-env-setup --proxy -                           # Disable proxy
#   ./linux-env-setup --neovim-version 0.10.0            # Custom neovim
#   ./linux-env-setup --reinstall neovim                 # Force reinstall
#
# Requirements: Ubuntu/Kali Linux, sudo access, internet connection
#
# =============================================================================

set -euo pipefail

readonly SCRIPT_NAME="${0##*/}"
readonly DEFAULT_NVIM_VERSION="0.12.1"
readonly DEFAULT_PROXY="http://127.0.0.1:7890"
readonly GVM_MIRROR="https://golang.google.cn/dl/"
readonly PYTHON_VERSION="3.12"

##------------------------------------------------------------------------------
## Helpers
##------------------------------------------------------------------------------

log_info()  { echo "==> $1"; }
log_warn()  { echo "WARNING: $1" >&2; }
log_error() { echo "ERROR: $1" >&2; exit 1; }

is_wsl() { grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; }

validate_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || log_error "Invalid $2: '$1'. Expected semver format"
}

normalize_proxy() {
  case "$1" in -|*|"") echo "$1" ;; http://*|https://*|socks*://*) echo "$1" ;; *) echo "http://$1" ;; esac
}

validate_proxy() {
  [[ "$1" == -* ]] && return 0
  [[ "$1" =~ ^(https?|socks[45]?):// ]] || log_error "Invalid proxy: '$1'. Must start with http://, https://, socks://, socks4://, or socks5://"
}

# Append to zshrc only if not already present (checks content, not just pattern)
append_zshrc() {
  local line="$1"
  local pattern="${2:-${line}}"
  [[ -z "$line" ]] && return 0  # Skip empty lines
  [[ -f ~/.zshrc ]] && grep -qF -- "$pattern" ~/.zshrc && return 0
  echo "$line" >> ~/.zshrc
}

command_exists() { command -v "$1" &>/dev/null; }

download_and_execute() {
  log_info "Downloading $2..."
  local temp_script
  temp_script=$(mktemp) || return 1
  trap "rm -f '$temp_script'" RETURN EXIT

  if ! curl --max-time 300 -fsSL "$1" -o "$temp_script"; then
    log_error "Failed to download $2"
    return 1
  fi

  # Basic validation - check if file is non-empty and starts with shebang
  if [[ ! -s "$temp_script" ]] || ! head -1 "$temp_script" | grep -q '^#!'; then
    log_error "Downloaded file is not a valid script"
    return 1
  fi

  log_info "Executing $2 installer..."
  chmod +x "$temp_script" && bash "$temp_script"
}

##------------------------------------------------------------------------------
## Install Status Checks
##------------------------------------------------------------------------------

nvim_is_installed() {
  command_exists nvim && nvim --version 2>/dev/null | head -1 | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+'
}

volta_is_installed() { command_exists volta; }
volta_tool_installed() { [[ -n "$(volta list "$1" 2>/dev/null)" ]]; }
gvm_is_installed() { [[ -x "$HOME/.local/bin/gvm" ]]; }

gvm_activate() {
  if [[ -s "${HOME}/.g/env" ]]; then
    # Source gvm env - temporarily disable set -u for GOPATH
    (set +u; source "$HOME/.g/env") 2>/dev/null || true
  fi
  export PATH="$HOME/.local/bin:$PATH"
}

# Check if Go is installed via gvm
gvm_go_installed() {
  gvm_activate
  command -v go &>/dev/null
}

##------------------------------------------------------------------------------
## Uninstall Functions
##------------------------------------------------------------------------------

uninstall_neovim() {
  if sudo -n true 2>/dev/null; then
    sudo rm -rf /opt/nvim /usr/local/bin/nvim /usr/bin/vi
    sudo update-alternatives --remove editor /usr/bin/vim.basic 2>/dev/null || true
  else
    rm -rf "$HOME/.local/nvim" "$HOME/.local/bin/nvim"
  fi
  log_info "Neovim uninstalled"
}

uninstall_volta() {
  for tool in node pnpm yarn bun; do volta_tool_installed "$tool" && volta uninstall "$tool" 2>/dev/null; done
  rm -rf "$HOME/.volta"
  sed -i '/VOLTA_HOME/d; /\.volta\/bin/d' ~/.zshrc 2>/dev/null || true
  log_info "Volta uninstalled"
}

uninstall_gvm() {
  rm -rf "$HOME/.g" "$HOME/.groot" "$HOME/.local/bin/gvm"
  sed -i '/# gvm shell setup/,/^\s*$/d; /G_MIRROR.*golang/d; /\.g\/env/d; /HOME.*\.local\/bin/d' ~/.zshrc 2>/dev/null || true
  log_info "gvm uninstalled"
}

##------------------------------------------------------------------------------
## Setup Functions
##------------------------------------------------------------------------------

setup_system_deps() {
  log_info "Setting up system dependencies..."

  if grep -qi kali /etc/os-release 2>/dev/null; then
    log_info "Detected Kali Linux"
    # Check if apt sources need updating
    if ! grep -q 'mirrors.tuna.tsinghua.edu.cn' /etc/apt/sources.list 2>/dev/null; then
      log_info "Updating Kali apt sources..."
      local sources_list="/etc/apt/sources.list"
      local temp_sources
      sudo cp "$sources_list" "${sources_list}.backup-$(date +%Y%m%d%H%M%S)" 2>/dev/null || true
      temp_sources=$(mktemp)
      trap "sudo mv '${sources_list}.backup-'* '$sources_list' 2>/dev/null || true; rm -f '$temp_sources'" RETURN

      sudo sed 's/^deb/# deb/g' "$sources_list" > "$temp_sources" 2>/dev/null || true
      echo 'deb https://mirrors.tuna.tsinghua.edu.cn/kali kali-rolling main non-free contrib non-free-firmware' | sudo tee -a "$temp_sources" > /dev/null 2>/dev/null || true
      sudo mv "$temp_sources" "$sources_list" 2>/dev/null || true
      trap - RETURN
    fi
  fi

  # Check if we can use sudo
  if ! sudo -n true 2>/dev/null; then
    log_warn "sudo not available, skipping system package installation"
    log_info "Please install required packages manually if needed"
    return 0
  fi

  # Install packages (continue on error for optional packages)
  sudo apt update || true
  sudo apt install -y git tmux tree cmake gcc zsh python3-pip ripgrep fd-find build-essential \
    luarocks ghostscript texlive-base texlive-binaries texlive-bibtex-extra biber latexmk \
    zathura zathura-pdf-poppler lazygit 2>/dev/null || log_warn "Some packages failed to install"
}

setup_proxy() {
  [[ "$PROXY" == "-" ]] && log_info "Proxy disabled" && return 0

  local proxy_line="export http_proxy=\"$PROXY\" https_proxy=\"$PROXY\""

  append_zshrc '# Proxy configuration' '# Proxy'
  append_zshrc "$proxy_line" "export http_proxy="

  export http_proxy="$PROXY" https_proxy="$PROXY"
  log_info "Proxy configured: $PROXY"
}

setup_git() {
  log_info "Setting up git..."
  git config --global alias.st status
  git config --global alias.cmt commit
  git config --global alias.ck checkout
  git config --global credential.helper store

  [[ "$PROXY" != "-" ]] && git config --global http.proxy "$PROXY"
}

setup_tmux() {
  log_info "Setting up tmux..."
  [[ -d ~/.tmux ]] && log_info "tmux already configured" && return 0

  git clone --depth 1 https://github.com/gpakosz/.tmux.git ~/.tmux
  ln -s -f .tmux/.tmux.conf ~/.tmux.conf

  is_wsl && log_info "Tip: For tmux errors, add 'export TMUX_TMPDIR=/tmp' to .zshrc"
}

setup_zsh() {
  log_info "Setting up zsh..."
  [[ -d ~/.oh-my-zsh ]] && log_info "zsh already configured" && return 0

  git clone --depth 1 https://github.com/ohmyzsh/ohmyzsh.git ~/.oh-my-zsh
  cp ~/.oh-my-zsh/templates/zshrc.zsh-template ~/.zshrc
  if chsh -s /bin/zsh 2>/dev/null; then
    log_info "Default shell changed to zsh"
  else
    log_warn "Could not change default shell. Run 'chsh -s /bin/zsh' manually."
  fi
  sed -i 's/ZSH_THEME=".*"/ZSH_THEME="bira"/' ~/.zshrc
}

# Setup shell tools and enhancements
setup_shell_tools() {
  log_info "Setting up shell tools..."

  # Vi mode for both bash and zsh
  append_zshrc '# Enable vi mode' '# Vi mode'
  append_zshrc 'set -o vi' 'set -o vi'

  # Zsh-specific settings
  append_zshrc '# Zsh enhancements' 'Zsh enhancements'
  append_zshrc 'bindkey -v' 'bindkey -v'
  append_zshrc 'export EDITOR="nvim"' 'export EDITOR='
  append_zshrc 'export VISUAL="nvim"' 'export VISUAL='

  # History settings
  append_zshrc '# History settings' 'History settings'
  append_zshrc 'HISTSIZE=10000' 'HISTSIZE='
  append_zshrc 'SAVEHIST=10000' 'SAVEHIST='
  append_zshrc 'HISTFILE=~/.zsh_history' 'HISTFILE='
  append_zshrc 'setopt HIST_IGNORE_DUPS HIST_FIND_NO_DUPS HIST_IGNORE_SPACE' 'HIST_IGNORE_DUPS'

  # Useful aliases
  append_zshrc '# Useful aliases' 'Useful aliases'
  append_zshrc "alias ..='cd ..'" 'alias ..='
  append_zshrc "alias ...='cd ../..'" 'alias ...='
  append_zshrc "alias la='ls -la'" 'alias la='
  append_zshrc "alias ll='ls -lah'" 'alias ll='

  log_info "Shell tools configured"
}

setup_git_extras() {
  log_info "Setting up git-extras..."
  mkdir -p ~/Project
  [[ -d ~/Project/git-extras ]] && log_info "git-extras already configured" && return 0

  git clone --depth 1 https://github.com/tj/git-extras.git ~/Project/git-extras
  append_zshrc 'source ~/Project/git-extras/etc/git-extras-completion.zsh' 'git-extras-completion'
}

setup_volta() {
  [[ "$REINSTALL_TOOL" == "volta" ]] && volta_is_installed && uninstall_volta
  volta_is_installed && log_info "Volta installed: $(volta --version)" && return 0

  log_info "Installing Volta..."
  download_and_execute "https://get.volta.sh" "Volta"

  export VOLTA_HOME="$HOME/.volta"
  export PATH="$VOLTA_HOME/bin:$PATH"

  for tool in node pnpm yarn bun; do
    volta_tool_installed "$tool" && log_info "$tool already installed" && continue
    [[ "$tool" == "node" ]] && volta install node || volta install "$tool" 2>/dev/null || log_warn "Failed to install $tool"
  done
}

setup_gvm() {
  local gvm_fresh_install="false"

  [[ "$REINSTALL_TOOL" == "gvm" ]] && gvm_is_installed && uninstall_gvm

  if gvm_is_installed; then
    gvm_activate
    log_info "gvm installed: $(gvm --version)"
    if gvm_go_installed; then
      log_info "Go installed: $(go version)"
      return 0
    fi
    log_info "gvm exists but Go not installed, installing..."
    gvm_fresh_install="true"
  else
    log_info "Installing gvm..."
    export G_MIRROR="$GVM_MIRROR"
    download_and_execute "https://raw.githubusercontent.com/voidint/g/master/install.sh" "gvm"

    mkdir -p "$HOME/.local/bin"
    ln -sf "$HOME/.g/bin/g" "$HOME/.local/bin/gvm"
    gvm_activate
    gvm_fresh_install="true"
  fi

  # Configure zshrc only on fresh install
  if [[ "$gvm_fresh_install" == "true" ]]; then
    append_zshrc '# gvm shell setup' '# gvm shell setup'
    append_zshrc "export G_MIRROR=\"$GVM_MIRROR\"" 'G_MIRROR'
    append_zshrc '[ -s "${HOME}/.g/env" ] && \. "${HOME}/.g/env"' '.g/env'
    append_zshrc 'export PATH="$HOME/.local/bin:$PATH"' '.local/bin:$PATH'
  fi

  log_info "Installing Go..."
  gvm install latest 2>&1 || true
  # gvm install returns 1 even on success, verify by checking version
  export GOROOT="${HOME}/.g/go"
  export GOPATH="${HOME}/go"
  export PATH="${HOME}/.g/bin:${GOROOT}/bin:${GOPATH}/bin:$PATH"
  if command -v go &>/dev/null; then
    log_info "Go installed: $(go version)"
  else
    log_warn "Go installation may have failed"
  fi
}

setup_neovim() {
  [[ "$REINSTALL_TOOL" == "neovim" ]] && nvim_is_installed &>/dev/null && uninstall_neovim

  if nvim_is_installed &>/dev/null; then
    log_info "Neovim installed: $(nvim_is_installed)"
    log_info "Skipping neovim installation (use --reinstall to force)"
  else
    log_info "Installing Neovim v${NVIM_VERSION}..."
    [[ "$(uname -m)" != "x86_64" ]] && log_error "Unsupported architecture"

    local download_dir="$HOME/Download"
    mkdir -p "$download_dir"
    cd "$download_dir"

    curl -fsSL -o nvim-linux-x86_64.tar.gz \
      "https://github.com/neovim/neovim/releases/download/v${NVIM_VERSION}/nvim-linux-x86_64.tar.gz"

    # Try system install first, fall back to user install
    if sudo -n true 2>/dev/null; then
      sudo rm -rf /opt/nvim
      tar -xzf nvim-linux-x86_64.tar.gz
      sudo mv nvim-linux-x86_64 /opt/nvim
      sudo ln -sf /opt/nvim/bin/nvim /usr/local/bin/nvim
      sudo ln -sf /opt/nvim/bin/nvim /usr/bin/vi
      sudo update-alternatives --set editor /usr/bin/vim.basic 2>/dev/null || true
    else
      log_info "Installing to user space (sudo not available)..."
      rm -rf "$HOME/.local/nvim"
      tar -xzf nvim-linux-x86_64.tar.gz
      mv nvim-linux-x86_64 "$HOME/.local/nvim"
      mkdir -p "$HOME/.local/bin"
      ln -sf "$HOME/.local/nvim/bin/nvim" "$HOME/.local/bin/nvim"
      ln -sf "$HOME/.local/nvim/bin/nvim" "$HOME/.local/bin/vi"
      export PATH="$HOME/.local/bin:$PATH"
    fi
    cd - > /dev/null
  fi

  log_info "Setting up neovim config..."
  mkdir -p ~/.vim/autoload
  curl --max-time 60 -o ~/.vim/autoload/plug.vim --create-dirs \
    https://gist.githubusercontent.com/vanpipy/5466dc623d6c9ec124f997ab7e6f2c70/raw/plug.vim
  curl --max-time 60 -o ~/.vimrc \
    https://gist.githubusercontent.com/vanpipy/0597d3ee27a55ecf8f1ad20cc044024e/raw/vimrc

  rm -rf ~/.config/nvim
  git clone --depth 1 https://github.com/vanpipy/lazible-neo.git ~/.config/nvim

  echo "==> Manual plugin setup:"
  echo "    nvim +'PlugInstall --sync' +qa"
  echo "    :CocInstall coc-tsserver coc-rome coc-eslint ..."
}

##------------------------------------------------------------------------------
## Main
##------------------------------------------------------------------------------

usage() {
  cat << EOF
Usage: $SCRIPT_NAME [OPTIONS]

Options:
  --neovim-version VERSION  Neovim version (default: ${DEFAULT_NVIM_VERSION})
  --reinstall TOOL          Reinstall tool (volta, gvm, neovim)
  --proxy PROXY             Proxy (default: ${DEFAULT_PROXY}, use "-" to disable)
  -h, --help               Show this help

Proxy Protocols:
  http://, https://, socks://, socks4://, socks5://

Examples:
  $SCRIPT_NAME
  $SCRIPT_NAME --proxy -                              # Disable proxy
  $SCRIPT_NAME --proxy http://192.168.1.1:8080       # HTTP proxy
  $SCRIPT_NAME --proxy socks5://127.0.0.1:7890      # SOCKS5 proxy
  $SCRIPT_NAME --neovim-version 0.10.0
  $SCRIPT_NAME --reinstall neovim
EOF
  exit 0
}

main() {
  local NVIM_VERSION="$DEFAULT_NVIM_VERSION"
  local PROXY="$DEFAULT_PROXY"
  local REINSTALL_TOOL=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage ;;
      --neovim-version)
        [[ -z "${2:-}" ]] && log_error "--neovim-version requires a value"
        validate_version "$2" "neovim version"
        NVIM_VERSION="$2"
        shift 2
        ;;
      --reinstall)
        [[ -z "${2:-}" ]] && log_error "--reinstall requires a value"
        REINSTALL_TOOL="$2"
        shift 2
        ;;
      --proxy)
        [[ -z "${2:-}" ]] && log_error "--proxy requires a value"
        validate_proxy "$2"
        PROXY="$2"
        shift 2
        ;;
      *) log_error "Unknown option: $1" ;;
    esac
  done

  export NVIM_VERSION PROXY REINSTALL_TOOL

  # Set proxy first - required for all network operations
  setup_proxy

  log_info "Starting setup... (Neovim: ${NVIM_VERSION}, Proxy: ${PROXY})"

  setup_system_deps
  setup_git
  setup_tmux
  setup_zsh
  setup_shell_tools
  setup_git_extras
  setup_volta
  setup_gvm
  setup_neovim
  # setup_pyenv  # Disabled by default

  echo ""
  echo "═══════════════════════════════════════════════════════════════"
  echo "  Setup complete!"
  echo ""
  echo "  ⚠️  IMPORTANT: Exit this shell and open a new one to apply"
  echo "     all environment changes (PATH, shell settings, etc.)"
  echo ""
  echo "  Or run: exec zsh"
  echo "═══════════════════════════════════════════════════════════════"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
