#!/usr/bin/env bash
#
# Push current branch to origin remote
#

set -euo pipefail

main() {
    local branch options

    branch=$(git branch --show-current 2>/dev/null) ||
        branch=$(git branch | grep '^\*' | awk '{print $2}')

    if [[ -z "$branch" ]]; then
        echo "Error: No current branch found" >&2
        exit 1
    fi

    options=()
    while [[ $# -gt 0 ]]; do
        options+=("$1")
        shift
    done

    echo "Pushing '$branch' to origin"
    git push "${options[@]}" -u origin "$branch"
}

main "$@"